{
  "title": "MCP Guardian — enterprise remediation metrics",
  "panels": [
    {
      "title": "Attacks blocked by rule",
      "targets": [{ "expr": "sum by (rule, tenant_id) (rate(mcp_guardian_attacks_blocked_total[5m]))" }]
    },
    {
      "title": "Semantic audit skipped",
      "targets": [{ "expr": "sum by (reason) (rate(mcp_guardian_semantic_audit_skipped_total[5m]))" }]
    },
    {
      "title": "Cost spent USD (tenant)",
      "targets": [{ "expr": "sum by (tenant_id) (mcp_guardian_cost_spent_usd)" }]
    }
  ]
}
