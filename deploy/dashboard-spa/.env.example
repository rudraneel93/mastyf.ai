# MCP Guardian SOC Dashboard — environment variables
#
# Copy to .env.local and adjust for your setup.

# ── API Backend ──────────────────────────────────────────────────────────────
#
# Port the SOC API backend listens on (default: 4040).
# next.config.ts uses this at startup to configure the /api/* rewrite.
SOC_API_PORT=4040

# Override to point the dashboard at a different host/port for the API.
# Leave commented out when running locally with next.config.ts rewrites.
# NEXT_PUBLIC_GUARDIAN_API=http://localhost:4040

# ── Multi-tenant / Auth ───────────────────────────────────────────────────────
# GUARDIAN_TENANT_ID=default
