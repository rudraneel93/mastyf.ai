# MCP Guardian Cloud control plane
# Copy to apps/cloud/.env.local and fill in secrets.

# App
AUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
AUTH_SECRET=generate-with-openssl-rand-base64-32

# OAuth — Google Cloud Console + GitHub OAuth App
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Database (separate DB from Guardian audit data recommended)
DATABASE_URL=postgresql://guardian:guardian@127.0.0.1:5432/mcp_guardian_cloud

# Shared secret for Guardian cloud-exchange session JWT (set same on Guardian as GUARDIAN_CLOUD_JWT_SECRET)
LICENSE_JWT_SECRET=generate-with-openssl-rand-base64-32
