# MCP Mastyf AI Cloud control plane
# Copy to apps/cloud/.env.local and fill in secrets.

# App
AUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
AUTH_SECRET=generate-with-openssl-rand-base64-32

# OAuth — Google Cloud Console + GitHub OAuth App
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Database (separate DB from Mastyf AI audit data recommended)
DATABASE_URL=postgresql://mastyf-ai-cloud

# Shared secret for Mastyf AI cloud-exchange session JWT (set same on Mastyf AI as MASTYF_AI_CLOUD_JWT_SECRET)
LICENSE_JWT_SECRET=generate-with-openssl-rand-base64-32

# Lemon Squeezy checkout URL (Pro $4.99 lifetime) — shown on homepage Buy button
NEXT_PUBLIC_PRO_CHECKOUT_URL=https://mastyf-ai.lemonsqueezy.com/checkout/buy/f725abfe-93c0-4bd7-8add-d15af13958fb

# Webhook auto-registration (production)
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_STORE_ID=
